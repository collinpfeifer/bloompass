generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  password           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  stripeAccountId    String?
  balance            Float  @default(0)
  onboardingComplete Boolean  @default(false)
  boughtTickets      Ticket[] @relation("BoughtTickets")
  sellingTickets     Ticket[] @relation("SellingTickets")
  banned             Boolean  @default(false)
}

model Ticket {
  id          String    @id @default(uuid())
  title       String
  description String?
  dateTime    DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  price       Int
  link        String    @unique
  sellerUserId      String
  sellerUser        User      @relation("SellingTickets", fields: [sellerUserId], references: [id])
  buyerUserId       String?
  buyerUser         User?     @relation("BoughtTickets", fields: [buyerUserId], references: [id])
  soldAt            DateTime?
  sold              Boolean   @default(false)
  hashtags    Hashtag[]
}
model Hashtag {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @unique
  tickets   Ticket[]
}
